# Copy this file to .env for local private settings.
# Do not commit .env or real passwords/API keys.

APP_ENV=local
CONTACT_EMAIL=

# Optional Version 2.0 AI assistant configuration.
# Create an OpenRouter key at https://openrouter.ai/ and keep it private.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
AI_TIMEOUT_SECONDS=30
APP_SITE_URL=https://github.com/Monokayser/Data-Visualization
APP_SITE_NAME=Data Visualization Dashboard
